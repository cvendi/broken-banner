---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
    const resources = await getCollection("resources");
    return resources.map((resource) => ({
        params: { slug: resource.id },
        props: { resource },
    }));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
const { title, author, description, cover, coverAlt, externalUrl, category } =
    resource.data;
---

<BaseLayout guild="Broken Banner" page={title}>
    <article class="max-w-3xl grid grid-cols-2 gap-8 px-4 py-10">
        <div class="col-span-1">
            {
                cover && (
                    <Image
                        src={cover}
                        alt={coverAlt ?? title}
                        class="rounded-xl mb-6 object-cover"
                    />
                )
            }
        </div>
        <div class="col-span-1">
            {
                category && (
                    <span class="inline-block text-xs uppercase tracking-wide text-gray-400 mb-2">
                        {category}
                    </span>
                )
            }
            <h1 class="text-3xl font-bold mb-2">{title}</h1>
            <p class="text-gray-400 mb-6">{description}</p>
            <p class="text-gray-400 mb-6">Posted by: {author}</p>
            {
                externalUrl && (
                    <a
                        href={externalUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-block mb-8 font-medium underline"
                    >
                        Visit resource →
                    </a>
                )
            }
        </div>
        <div class="prose prose-invert max-w-none">
            <Content />
        </div>
    </article>
</BaseLayout>

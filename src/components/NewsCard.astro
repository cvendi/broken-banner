---
import { Card, CardContent } from "@/components/starwind/card";
import { Image } from "astro:assets";

const { title, postUrl, description, cover, coverAlt, externalUrl, category } =
    Astro.props;
---

<a href={postUrl} class="block h-[21rem] min-w-0 sm:h-[22rem]">
    <Card
        class="relative mx-auto h-full w-full max-w-sm gap-0 overflow-hidden border-transparent bg-card-bg py-0 ring-border-accent transition-colors hover:ring-legendary-accent"
    >
        {
            cover && (
                <Image
                    src={cover}
                    alt={coverAlt ?? title}
                    class="aspect-video w-full shrink-0 object-cover"
                />
            )
        }
        <CardContent
            class="flex min-h-0 flex-1 flex-col gap-3 p-4 text-body-text sm:p-5"
        >
            <span
                class="line-clamp-2 break-words font-header text-xl font-semibold leading-tight"
            >
                {title}
            </span>
            <p
                class="line-clamp-3 break-words text-sm leading-6 text-text-muted"
            >
                {description}
            </p>
            {
                category && (
                    <span class="mt-auto w-fit max-w-full truncate rounded-full bg-border-accent/20 px-2.5 py-1 text-xs font-medium uppercase tracking-wide text-text-muted">
                        {category}
                    </span>
                )
            }
        </CardContent>
    </Card>
</a>

---
const { name, playerClass, playerSpec, playerRole, score, scoreColor } =
    Astro.props;

const resolvedScoreColor =
    typeof scoreColor === "string" && scoreColor.trim().length > 0
        ? scoreColor.trim()
        : undefined;

import {
    Card,
    CardContent,
    CardDescription,
    CardFooter,
    CardHeader,
    CardTitle,
} from "@/components/starwind/card";
---

<Card
    size="sm"
    class="mx-auto w-full max-w-sm border-l-4 bg-card-bg ring-border-accent"
    style={resolvedScoreColor
        ? `border-left-color: ${resolvedScoreColor};`
        : undefined}
>
    <CardHeader>
        <CardTitle><p class="text-body-text text-2xl">{name}</p></CardTitle>
        <CardDescription
            ><p class="text-text-muted">
                {playerClass} • {playerSpec} • {playerRole}
            </p></CardDescription
        >
    </CardHeader>
    <CardContent>
        <p
            class="text-4xl"
            style={resolvedScoreColor
                ? `color: ${resolvedScoreColor};`
                : undefined}
        >
            {score}
        </p>
    </CardContent>
</Card>

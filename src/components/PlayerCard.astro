---
const { name, playerClass, playerSpec, playerRole, score, scoreColor } =
    Astro.props;

const resolvedScoreColor =
    typeof scoreColor === "string" && scoreColor.trim().length > 0
        ? scoreColor.trim()
        : undefined;

import {
    Card,
    CardContent,
    CardDescription,
    CardFooter,
    CardHeader,
    CardTitle,
} from "@/components/starwind/card";

import { Shield, HeartPulse, Swords } from "@lucide/astro";

const ROLE_ICONS = {
    TANK: { icon: Shield, color: 'cyan' },
    HEALING: { icon: HeartPulse, color: 'green' },
    DPS: { icon: Swords, color: 'red' },
};

const CLASS_COLORS = {
  'Death Knight': '#C41F3B',
  'Demon Hunter': '#A330C9',
  'Druid': '#FF7D0A',
  'Hunter': '#ABD473',
  'Mage': '#69CCF0',
  'Monk': '#00FF96',
  'Paladin': '#F58CBA',
  'Priest': '#FFFFFF',
  'Rogue': '#FFF569',
  'Shaman': '#0070DE',
  'Warlock': '#8787ED',
  'Warrior': '#C79C6E',
};
---

<Card
    size="sm"
    class="mx-auto w-full max-w-sm border-l-4 bg-card-bg ring-border-accent"
    style={resolvedScoreColor
        ? `border-left-color: ${resolvedScoreColor};`
        : undefined}
>
    <CardHeader>
        <CardTitle
            ><p class="text-body-text text-2xl flex justify-between items-center">
                <span style={{ color: CLASS_COLORS[playerClass] }}>{name}</span>
                <img
                    src={`https://wow.zamimg.com/images/wow/icons/large/classicon_${playerClass.toLowerCase()}.jpg`}
                    class="w-8 h-8 rounded-full object-cover"
                />
            </p></CardTitle
        >
        <CardDescription
            ><p class="text-text-muted flex justify-between items-center mr-1">
                {playerSpec} {playerRole && <ROLE_ICONS[playerRole.toUpperCase()].icon style={{ color: ROLE_ICONS[playerRole.toUpperCase()].color }} />}
            </p></CardDescription
        >
    </CardHeader>
    <CardContent>
        <p
            class="text-4xl"
            style={resolvedScoreColor
                ? `color: ${resolvedScoreColor};`
                : undefined}
        >
            {score}
        </p>
    </CardContent>
</Card>

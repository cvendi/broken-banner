---
const navLinks = [
    { href: "/", label: "Home", variant: "text" },
    { href: "/news", label: "News", variant: "text" },
    { href: "/roster", label: "Roster", variant: "text" },
    { href: "/join", label: "Join", variant: "button" },
];

import { Button } from "@/components/starwind/button";
import { Swords } from "@lucide/astro";
import { SiDiscord } from "react-icons/si";
---

<header
    class="bg-page-bg font-header border-b border-border-accent shadow-1xl sticky top-0 z-20 mb-2"
>
    <div
        class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-6 py-4 sm:px-8 lg:px-10 xl:px-12"
    >
        <details class="mobile-nav group order-2 ml-auto md:hidden">
            <summary
                class="order-2 flex h-11 w-11 shrink-0 list-none items-center justify-center rounded-md border border-border text-body-text transition-colors hover:text-legendary-accent [&::-webkit-details-marker]:hidden"
            >
                <span class="sr-only">Toggle navigation menu</span>
                <svg
                    class="h-6 w-6 group-open:hidden"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M4 7h16"></path>
                    <path d="M4 12h16"></path>
                    <path d="M4 17h16"></path>
                </svg>
                <svg
                    class="hidden h-6 w-6 group-open:block"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <path d="M18 6 6 18"></path>
                    <path d="m6 6 12 12"></path>
                </svg>
            </summary>

            <nav aria-label="Primary" class="order-1 flex-1">
                <ul
                    class="flex flex-wrap items-center justify-end gap-x-5 gap-y-3 pr-4 text-lg text-body-text"
                >
                    {
                        navLinks.map((link) => (
                            <li>
                                {link.variant === "button" ? (
                                    <a
                                        class="text-epic-accent text-base"
                                        href={link.href}
                                    >
                                        {link.label}
                                    </a>
                                ) : (
                                    <a
                                        class="transition-colors hover:text-legendary-accent"
                                        href={link.href}
                                    >
                                        {link.label}
                                    </a>
                                )}
                            </li>
                        ))
                    }
                </ul>
            </nav>
        </details>

        <h1
            class="site-logo order-1 shrink-0 text-body-text transition-colors hover:text-legendary-accent md:order-0 md:text-7xl"
        >
            <a href="/" class="inline-flex items-center gap-2">
                <Swords size="32" aria-hidden="true" />
                <span class="md:text-4xl text-xl">Broken Banner</span>
            </a>
        </h1>

        <nav aria-label="Primary" class="hidden md:block">
            <ul
                class="flex flex-wrap items-center justify-center gap-x-9 gap-y-4 text-lg text-body-text md:text-2xl"
            >
                {
                    navLinks.map((link) => (
                        <li>
                            {link.variant === "button" ? (
                                <Button
                                    class="bg-card-bg border border-epic-accent text-xl hover:bg-epic-accent"
                                    href={link.href}
                                    variant="default"
                                    size="lg"
                                >
                                    {link.label}
                                </Button>
                            ) : (
                                <a
                                    class="transition-colors hover:text-legendary-accent"
                                    href={link.href}
                                >
                                    {link.label}
                                </a>
                            )}
                        </li>
                    ))
                }
                <a class="transition-colors hover:text-blue-400" href="#"
                    ><SiDiscord /></a
                >
            </ul>
        </nav>
    </div>
</header>

<style>
    @media (max-width: 767px) {
        .mobile-nav[open] {
            display: flex;
            width: 100%;
            align-items: center;
            justify-content: flex-end;
        }

        .mobile-nav[open] + .site-logo {
            display: none;
        }
    }
</style>
